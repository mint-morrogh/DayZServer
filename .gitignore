# ==========================================
# DayZ Server - Git Ignore
# Only track config files, mission customizations,
# mod folders, and launch scripts.
# ==========================================

# --- Ignore everything by default ---
*

# --- Allow top-level config & launch files ---
!.gitignore
!README.md
!serverDZ.cfg
!start.bat
!apply_settings.bat
!apply_settings.ps1
!server_settings.json
!whitelist.txt
!ban.txt

# --- Allow mod folders (configs/docs only, not binaries) ---
!@*/
!@*/**
# Ignore compiled mod binaries (users download fresh from Workshop)
@*/addons/
@*/keys/

# --- Allow server keys folder ---
!keys/
!keys/*.bikey

# --- Allow mission folder ---
!mpmissions/
!mpmissions/dayzOffline.chernarusplus/
!mpmissions/dayzOffline.chernarusplus/**

# Ignore persistence/runtime data inside mission
mpmissions/dayzOffline.chernarusplus/storage_0/
mpmissions/dayzOffline.chernarusplus/storage_1/
mpmissions/dayzOffline.chernarusplus/backups/

# --- Ignore game binaries & engine files ---
*.exe
*.dll
*.pbo
*.bisign
*.bikey
*.bin
*.map
dayz.gproj
dayzsetting.xml
steam_appid.txt

# --- Ignore engine/data folders ---
addons/
bliss/
dta/
docs/
sakhal/
server_manager/

# --- Allow config folder (mod configs only, not logs/runtime) ---
!config/
config/*
!config/CarePackagesV2/
!config/CarePackagesV2/**
!config/Zenarchist/
!config/Zenarchist/**
!config/Dayz-Dog/
!config/Dayz-Dog/**
!config/DayZ-Horse/
!config/DayZ-Horse/**
!config/PvZmoD_CustomisableZombies_Profile/
!config/PvZmoD_CustomisableZombies_Profile/**
!config/ExpansionMod/
!config/ExpansionMod/Settings/
!config/ExpansionMod/Settings/**
!config/Trader/
!config/Trader/**
!config/MMIO/
!config/MMIO/**
!config/NCPR/
!config/NCPR/**
!config/DZR/
!config/DZR/**
!config/NotificationsSystem/
!config/NotificationsSystem/**
!config/PvZmoD_Information_Panel/
!config/PvZmoD_Information_Panel/**
!config/VPPMapConfig.json

# Ignore player-specific runtime data inside Zenarchist
config/Zenarchist/Skills/Analytics/
config/Zenarchist/Skills/PlayerDB/
config/Zenarchist/Skills/ZenSkillsHighscoresDB.json

# Ignore runtime logs and data inside config
config/Dayz-Dog/*.log
config/ExpansionMod/Logs/
config/EventManagerLog/
config/WebApiLog/
config/DataCache/
config/BattlEye/
config/Users/
config/CW_Gamelabs/
config/@GameLabsStorage/
config/@CREATE_GAMELABS_CFG_HERE/
config/CarePackageV2/
