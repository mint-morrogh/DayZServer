				<spawn configName="Doggo_Wild12" chance="1" />
				<spawn configName="Doggo_Wild13" chance="1" />
				<spawn configName="Doggo_Wild14" chance="1" />
				<spawn configName="Doggo_Wild15" chance="1" />
