				<spawn configName="Doggo_Wild29" chance="1" />
				<spawn configName="Doggo_Wild30" chance="1" />
				<spawn configName="Doggo_Wild31" chance="1" />
				<spawn configName="Doggo_Wild32" chance="1" />
