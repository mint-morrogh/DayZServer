{
    "_README": "Edit the values below and run apply_settings.bat to patch all server config files at once.",

    "server": {
        "name": "BAE-Z",
        "password": "mintmorrogh",
        "adminPassword": "mintmorrogh",
        "maxPlayers": 4
    },

    "time": {
        "_help": "acceleration=1 is real time. 6 means a full day passes in ~4 hours. nightAcceleration multiplies ON TOP of acceleration.",
        "startTime": "2000/07/01/08/00",
        "acceleration": 6,
        "nightAcceleration": 4,
        "persistent": true
    },

    "network": {
        "vonEnabled": true,
        "vonQuality": 20,
        "thirdPerson": true,
        "crosshair": true
    },

    "gameplay": {
        "_help": "These require enableCfgGameplayFile=1 in serverDZ.cfg (already set).",
        "disableBaseDamage": false,
        "disableContainerDamage": false,
        "staminaMax": 100.0,
        "staminaMinCap": 5.0,
        "staminaWeightThreshold": 6000.0,
        "sprintStaminaModifier": 1.0,
        "meleeStaminaModifier": 1.0,
        "showPlayerOnMap": true,
        "mapWithoutItem": false,
        "compassWithoutItem": false,
        "use3DMap": false,
        "lightingConfig": 0,
        "relaxedBaseBuilding": false,
        "shockRefillSpeedConscious": 5.0,
        "shockRefillSpeedUnconscious": 1.0,
        "timeToSprint": 0.45,
        "rotationSpeedJog": 0.3,
        "boatDecayMultiplier": 1.0
    },

    "zombies": {
        "_help": "nominal=how many spawn near you, min=minimum alive on map, max=hard cap. Set nominal to 0 to disable a category.",
        "city":           { "nominal": 25, "min": 12, "max": 120 },
        "cityCoastal":    { "nominal":  6, "min":  3, "max":  30 },
        "military":       { "nominal": 25, "min": 12, "max": 120 },
        "militaryHard":   { "nominal": 25, "min": 12, "max": 120 },
        "village":        { "nominal": 20, "min": 10, "max":  50 },
        "villageCoastal": { "nominal":  6, "min":  3, "max":  15 },
        "wilderness":     { "nominal":  2, "min":  1, "max":   8 },
        "police":         { "nominal": 20, "min": 10, "max":  50 },
        "policeHard":     { "nominal": 20, "min": 10, "max":  50 },
        "medic":          { "nominal": 20, "min": 10, "max":  50 },
        "firefighter":    { "nominal": 20, "min": 10, "max":  50 },
        "industrial":     { "nominal": 20, "min": 10, "max":  50 },
        "religious":      { "nominal": 20, "min": 10, "max":  50 },
        "prisoner":       { "nominal": 20, "min": 10, "max":  50 },
        "nbc":            { "nominal": 25, "min": 12, "max": 120 }
