{
    "_README": "Edit the values below and run apply_settings.bat to patch all server config files at once.",

    "server": {
        "name": "Blood & Barter",
        "password": "mintmorrogh",
        "adminPassword": "mintmorrogh",
        "maxPlayers": 4
    },

    "time": {
        "_help": "acceleration=1 is real time. 6 means a full day passes in ~4 hours. nightAcceleration multiplies ON TOP of acceleration.",
        "startTime": "2000/07/01/08/00",
        "acceleration": 6,
        "nightAcceleration": 4,
        "persistent": true
    },

    "network": {
        "vonEnabled": true,
        "vonQuality": 20,
        "thirdPerson": true,
        "crosshair": true
    },

    "gameplay": {
        "_help": "These require enableCfgGameplayFile=1 in serverDZ.cfg (already set).",
        "disableBaseDamage": false,
        "disableContainerDamage": false,
        "staminaMax": 100.0,
        "staminaMinCap": 5.0,
        "staminaWeightThreshold": 6000.0,
        "sprintStaminaModifier": 1.0,
        "meleeStaminaModifier": 1.0,
        "showPlayerOnMap": false,
        "mapWithoutItem": false,
        "compassWithoutItem": false,
        "use3DMap": false,
        "lightingConfig": 0,
        "relaxedBaseBuilding": false
    },

    "zombies": {
        "_help": "nominal=how many spawn near you, min=minimum alive on map, max=hard cap. Set nominal to 0 to disable a category.",
        "city":           { "nominal": 25, "min": 12, "max": 120 },
        "cityCoastal":    { "nominal":  6, "min":  3, "max":  30 },
        "military":       { "nominal": 25, "min": 12, "max": 120 },
        "militaryHard":   { "nominal": 25, "min": 12, "max": 120 },
        "village":        { "nominal": 20, "min": 10, "max":  50 },
        "villageCoastal": { "nominal":  6, "min":  3, "max":  15 },
        "wilderness":     { "nominal":  2, "min":  1, "max":   8 },
        "police":         { "nominal": 20, "min": 10, "max":  50 },
        "policeHard":     { "nominal": 20, "min": 10, "max":  50 },
        "medic":          { "nominal": 20, "min": 10, "max":  50 },
        "firefighter":    { "nominal": 20, "min": 10, "max":  50 },
        "industrial":     { "nominal": 20, "min": 10, "max":  50 },
        "religious":      { "nominal": 20, "min": 10, "max":  50 },
        "prisoner":       { "nominal": 20, "min": 10, "max":  50 },
        "nbc":            { "nominal": 25, "min": 12, "max": 120 }
    },

    "zombieBehavior": {
        "_help": "PvZmoD zombie behaviour. Clamp caps speed: 1.5=walk, 2.5=run, 3.0=sprint. Ratios multiply vanilla values (0.5=half, 1.0=vanilla, 2.0=double).",
        "speedClampMaxDay": 2.5,
        "speedClampMaxNight": 3.0,
        "speedRatioDay": 0.75,
        "speedRatioNight": 0.95,
        "healthRatioDay": 0.7,
        "healthRatioNight": 1.0,
        "strengthRatioDay": 1.3,
        "strengthRatioNight": 1.0,
        "visionRatioDay": 0.65,
        "visionRatioNight": 0.8
    },

    "animals": {
        "_help": "Wild animal spawn counts in events.xml. nominal=target herds on map, min=respawn trigger, max=max children per herd.",
        "wildDogs":   { "nominal": 6, "min": 1, "max": 5 },
        "wildHorses": { "nominal": 8, "min": 1, "max": 4 }
    },

    "horseGear": {
        "_help": "Horse tack spawn counts in types_dayzhorse.xml. nominal=max on map, min=respawn trigger.",
        "saddle":    { "nominal": 5, "min": 3 },
        "bridle":    { "nominal": 5, "min": 3 },
        "horseBags": { "nominal": 4, "min": 2 },
        "stableKit": { "nominal": 3, "min": 1 }
    },

    "dogGear": {
        "_help": "Dog accessory spawn counts in types_dayzdog.xml. nominal=max on map per item, min=respawn trigger. Applies to all colour variants.",
        "collar":      { "nominal": 3, "min": 1 },
        "vest":        { "nominal": 3, "min": 1 },
        "gasMask":     { "nominal": 3, "min": 1 },
        "dogHouseKit": { "nominal": 3, "min": 1 }
    },

    "planes": {
        "_help": "Plane spawn counts in types_lmplanes.xml. Set nominal to 0 to remove a plane type. Keep total under 15-30 for performance.",
        "dc3":          { "nominal": 3, "min": 2 },
        "stuntplane":   { "nominal": 2, "min": 1 },
        "catalina":     { "nominal": 3, "min": 2 },
        "tigermoth":    { "nominal": 2, "min": 1 },
        "tigermothMk2": { "nominal": 1, "min": 1 },
        "tigermothMk3": { "nominal": 1, "min": 1 },
        "spitfire":     { "nominal": 3, "min": 2 },
        "cessna":       { "nominal": 3, "min": 2 }
    },

    "sleep": {
        "_help": "Zen's Sleep fatigue settings. drainMultiplier: lower=slower fatigue drain (0.4=relaxed, 1.0=vanilla, 0.0=no fatigue).",
        "globalDrainMultiplier": 0.4
    },

    "lootEconomy": {
        "_help": "Global loot economy from globals.xml. ZombieMaxCount caps total zombies server-wide. AnimalMaxCount caps animals.",
        "zombieMaxCount": 500,
        "animalMaxCount": 200,
        "lootDamageMin": 0.0,
        "lootDamageMax": 0.82,
        "foodDecay": 1,
        "cleanupLifetimeDeadPlayer": 3600,
        "cleanupLifetimeRuined": 330,
        "respawnLimit": 20,
        "flagRefreshFrequency": 432000,
        "flagRefreshMaxDuration": 3456000
    },

    "zenSkills": {
        "_help": "Spawn rates for Zenarchist's Skills items. nominal=max on map, min=respawn trigger.",
        "expBoostInjector":  { "nominal": 10, "min": 5 },
        "perkResetInjector": { "nominal":  4, "min": 2 },
        "survivalBook":      { "nominal":  6, "min": 3 },
        "craftingBook":      { "nominal":  6, "min": 3 },
        "huntingBook":       { "nominal":  6, "min": 3 },
        "gatheringBook":     { "nominal":  6, "min": 3 }
    }
}
