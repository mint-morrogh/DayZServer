    "zombieBehavior": {
        "_help": "PvZmoD zombie behaviour. Clamp caps speed: 1.5=walk, 2.5=run, 3.0=sprint. Ratios multiply vanilla values (0.5=half, 1.0=vanilla, 2.0=double).",
        "speedClampMaxDay": 2.5,
        "speedClampMaxNight": 3.0,
        "speedRatioDay": 0.75,
        "speedRatioNight": 0.95,
        "healthRatioDay": 0.7,
        "healthRatioNight": 1.0,
        "strengthRatioDay": 1.3,
        "strengthRatioNight": 1.0,
        "visionRatioDay": 0.65,
        "visionRatioNight": 0.8
    },

    "zombieFeatures": {
        "_help": "PvZmoD feature toggles (0=off, 1=on). Day/Night pairs. Stone throwing, door breaking, bleeding, etc.",
        "bleedingChanceDay": 0,
        "bleedingChanceNight": 0,
        "doorBreakingDay": 1,
        "doorBreakingNight": 1,
        "lockedDoorBreakingDay": 0,
        "lockedDoorBreakingNight": 0,
        "hitUnconsciousDay": 0,
        "hitUnconsciousNight": 0,
        "stoneThrowing": {
            "_help": "Zombies throw stones at players on obstacles. damage=health per hit, shock=shock per hit, rate=seconds between throws, distanceMax=range.",
            "enabledDay": 1,
            "enabledNight": 1,
            "onlyOnObstacleDay": 1,
            "onlyOnObstacleNight": 1,
            "damageHealthDay": 2.5,
            "damageHealthNight": 2.5,
            "damageShockDay": 15.0,
            "damageShockNight": 15.0,
            "keepMinHealthDay": 30.0,
            "keepMinHealthNight": 30.0,
            "rateDay": 5.0,
            "rateNight": 5.0,
            "distanceMaxDay": 10.0,
            "distanceMaxNight": 10.0
        },
        "vehicleDamage": {
            "_help": "Damage to vehicle radiator when running over zombies. 0=off, 1=on.",
            "enabled": 1,
            "damagePerImpact": 1.0,
            "timerBetweenImpacts": 5,
            "speedMinimum": 5
        },
        "vehicleAttack": {
            "_help": "Zombies attack stopped/slow vehicles. damageStructure/attachments per hit.",
            "enabled": 1,
            "damageOnStructure": 2.0,
            "damageOnAttachments": 5.0,
            "attackSpeedFactor": 1.0,
            "playerInsideCanBeHit": 1
